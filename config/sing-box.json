{
  "dns": {
    "rules": [
      {
        "domain_suffix": [
          ".cn"
        ],
        "server": "local"
      }
    ],
    "servers": [
      {
        "address": "223.5.5.5",
        "detour": "direct",
        "tag": "local"
      },
      {
        "address": "8.8.8.8",
        "detour": "proxy",
        "tag": "remote"
      }
    ],
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "listen": "",
      "listen_port": 10800,
      "sniff": true,
      "tag": "mixed-in",
      "type": "mixed"
    }
  ],
  "log": {
    "level": "info",
    "timestamp": true
  },
  "outbounds": [
    {
      "tag": "direct",
      "type": "direct"
    },
    {
      "tag": "block",
      "type": "block"
    },
    {
      "tag": "dns-out",
      "type": "dns"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "final": "direct",
    "rules": [
      {
        "outbound": "dns-out",
        "protocol": [
          "dns"
        ]
      }
    ]
  }
}